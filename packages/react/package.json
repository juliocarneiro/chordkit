{
  "name": "@chordkit/react",
  "version": "1.0.4",
  "description": "React components and hooks for chordkit — ChordChart, ChordProgression, ChordEditor",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "chord",
    "react",
    "component",
    "svg",
    "guitar",
    "chordkit"
  ],
  "license": "MIT",
  "author": "Julio Carneiro",
  "repository": {
    "type": "git",
    "url": "https://github.com/juliocarneiro/chordkit",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/juliocarneiro/chordkit#readme",
  "bugs": {
    "url": "https://github.com/juliocarneiro/chordkit/issues"
  },
  "peerDependencies": {
    "chordkit": "^1.0.0",
    "react": ">=17",
    "react-dom": ">=17"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "jsdom": "^28.1.0"
  },
  "sideEffects": false
}
