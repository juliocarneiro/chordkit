{
  "name": "@chordkit/dictionary",
  "version": "1.0.0",
  "description": "Pre-built chord definitions for chordkit (guitar, ukulele, and more)",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "chord",
    "dictionary",
    "guitar",
    "ukulele",
    "chordkit"
  ],
  "license": "MIT",
  "peerDependencies": {
    "chordkit": "^1.0.0"
  },
  "sideEffects": false
}
